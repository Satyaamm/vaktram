{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/docs",
      "destination": "https://docs.vaktram.com",
      "permanent": false
    },
    {
      "source": "/docs/:path*",
      "destination": "https://docs.vaktram.com/:path*",
      "permanent": false
    }
  ]
}
