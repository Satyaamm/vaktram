# ============================================
# SUPABASE
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
# DATABASE_URL is auto-derived from SUPABASE_DB_URL by the API (asyncpg driver added automatically)

# ============================================
# UPSTASH
# ============================================
UPSTASH_REDIS_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_TOKEN=AXxxxxx
QSTASH_URL=https://qstash-xxxxx.upstash.io
QSTASH_TOKEN=eyJxxxxx
QSTASH_CURRENT_SIGNING_KEY=sig_xxxxx
QSTASH_NEXT_SIGNING_KEY=sig_xxxxx

# ============================================
# DEFAULT LLM (Gemini — free, no card)
# ============================================
GOOGLE_AI_API_KEY=AIzaxxxxx
DEFAULT_LLM_MODEL=gemini/gemini-2.0-flash

# ============================================
# ENCRYPTION (for user API keys)
# ============================================
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# ============================================
# HUGGINGFACE (for pyannote access)
# ============================================
HF_TOKEN=hf_xxxxx

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:8000
BOT_SERVICE_URL=http://localhost:8001
ENVIRONMENT=development

# ============================================
# GOOGLE OAUTH (for calendar integration)
# ============================================
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPx-xxxxx
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# ============================================
# SUPABASE JWT (for token verification)
# ============================================
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ============================================
# SENTRY
# ============================================
SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ============================================
# OPTIONAL: ASSEMBLYAI (100hrs free backup)
# ============================================
ASSEMBLYAI_API_KEY=xxxxx
