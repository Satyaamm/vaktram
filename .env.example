# ─────────────────────────────────────────────────────────────────────────
# Vaktram environment
#
# This file is the contract between code and config: every variable below
# is read somewhere in the codebase, with the section comments saying
# where. Anything not in this file is not used.
#
# Generate the local .env with:
#     cp .env.example .env
# then fill in the REQUIRED block. Everything below it is optional and has
# sane defaults.
# ─────────────────────────────────────────────────────────────────────────


# ============================================================
# REQUIRED — the API refuses to boot in production without these
# ============================================================

# Postgres connection (Supabase pooler URL works directly). The driver is
# auto-rewritten to asyncpg if you paste a plain postgresql:// URL.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/vaktram

# JWT signing secret. ≥32 chars. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# SUPABASE_JWT_SECRET is accepted as an alias if you'd rather reuse that.
JWT_SECRET=your-jwt-secret-here

# Fernet symmetric key for encrypting user-supplied LLM API keys at rest.
# Generate with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# Shared secret authenticating internal callers (bot service, workers) to
# the API. The SAME value must be set on the API host, the bot VPS, and
# every worker process. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
BOT_SHARED_SECRET=your-bot-shared-secret-here

# Supabase Storage — used by the bot service uploader and workers to
# read/write meeting audio. Service-role key is required (bypasses RLS for
# the audio bucket). NEVER ship to the frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key

# Groq Whisper — transcription. Free tier is 10 hr/day per workspace.
GROQ_API_KEY=gsk_your_groq_api_key_here

# Resend — transactional email (verification, password reset, welcome).
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=no-reply@vaktram.com


# ============================================================
# JOB QUEUE + CACHE (Upstash). Required for prod; optional for local dev
#                  (the API falls back to inline pipeline execution).
# ============================================================
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token

QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_your_current_key
QSTASH_NEXT_SIGNING_KEY=sig_your_next_key


# ============================================================
# APP URLS — set these per environment
# ============================================================
# Where the dashboard lives (apps/web)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Where the marketing site lives (apps/website)
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3001
# Where the API lives
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend mirrors of the URLs above (used inside redirect / email links)
API_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000

# Drives a few production-only behaviours:
#   • Cookies set with Secure + SameSite=None
#   • API refuses to boot if JWT_SECRET / BOT_SHARED_SECRET are missing
#   • QStash signature verification is mandatory
ENVIRONMENT=development


# ============================================================
# CALENDAR — Google OAuth (only if you sync calendars)
# ============================================================
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret


# ============================================================
# BOT SERVICE — these are read on the VPS, not the API host.
# Forwarded by infra/scripts/deploy-bot-vps.sh from this file.
# ============================================================
# Where the bot calls back into the API
API_URL=http://localhost:8000
BOT_SERVICE_URL=http://localhost:8001
BOT_SERVICE_PORT=8001

# Audio capture
HEADLESS=true
PULSE_SERVER=unix:/tmp/pulseaudio.socket

# Lifecycle limits (seconds)
BOT_MAX_DURATION_SEC=10800
BOT_END_CHECK_INTERVAL_SEC=10

# Region pinning for storage paths
REGION=ap-southeast-1
STORAGE_BUCKET=vaktram-audio

# Optional bot extras
# ZOHO_MEETING_PASSWORD=
# CAPTCHA_API_KEY=                     # 2Captcha / Anti-Captcha (Zoho join)
# VAKTRAM_CONSENT_MESSAGE=             # Override the default chat disclosure


# ============================================================
# DIARIZATION SERVICE (apps/workers/diarization, optional)
# ============================================================
# DIARIZATION_SERVICE_URL=http://localhost:8002
# HF_TOKEN=hf_your_token_here          # required by pyannote 3.1


# ============================================================
# WORKER FALLBACK LLM (only used when a user has no BYOM config)
# ============================================================
# DEFAULT_LLM_PROVIDER=gemini
# DEFAULT_LLM_MODEL=gemini-2.0-flash
# DEFAULT_LLM_API_KEY=


# ============================================================
# OPTIONAL — observability, billing, enterprise SSO
# ============================================================
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.1
# OTEL_EXPORTER_ENDPOINT=

# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO=
# STRIPE_PRICE_TEAM=
# STRIPE_PRICE_BUSINESS=

# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=


# ============================================================
# COMPLIANCE — defaults are fine for most tenants
# ============================================================
# AUDIT_EXPORT_BUCKET=                 # S3 bucket for hourly audit-log export
# DEFAULT_RETENTION_DAYS=365


# ============================================================
# CORS — defaults allow localhost + any *.vercel.app
# ============================================================
# CORS_ORIGINS=https://app.vaktram.com,https://vaktram.com
# CORS_ORIGIN_REGEX=^https://[a-zA-Z0-9-]+\.vercel\.app$
# RATE_LIMIT_PER_MINUTE=60
